import org.junit.jupiter.api.BeforeAll;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.MethodOrderer;
import org.junit.jupiter.api.Order;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.TestInstance;
import org.junit.jupiter.api.TestInstance.Lifecycle;
import org.junit.jupiter.api.TestMethodOrder;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.webmvc.test.autoconfigure.AutoConfigureMockMvc;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;
import org.springframework.test.web.servlet.MvcResult;

import com.blockbuster.dto.RefreshRequest;
import com.blockbuster.dto.RefreshResponse;
import com.blockbuster.dto.SignInRequest;
import com.blockbuster.dto.SignInResponse;
import com.blockbuster.dto.SignUpRequest;
import com.blockbuster.dto.SignUpResponse;

import tools.jackson.databind.ObjectMapper;

@TestInstance(Lifecycle.PER_CLASS)
@TestMethodOrder(MethodOrderer.OrderAnnotation.class)
@SpringBootTest
@AutoConfigureMockMvc
class AuthenticationServiceApplicationTests {

	@Autowired
	private MockMvc mvc;
	
	@Autowired
	private ObjectMapper objectMapper;
	
	private String accessToken;
	private String refreshToken;
	private String newAccessToken;
	private String newRefreshToken;
	
	@BeforeAll
	void setup() throws Exception {
		
		SignUpRequest signup=new SignUpRequest("jackapple559@gmail.com","pass123",Set.of("User"));
		mvc.perform(
					post("/api/users/signup")
						.contentType(MediaType.APPLICATION_JSON)
						.content(objectMapper.writeValueAsString(signup))
					
				)
				.andDo(print())
				.andExpect(status().isOk())
				.andReturn();
		SignInRequest signin=new SignInRequest("jackapple559@gmail.com","pass123","deviceA");
		MvcResult signinResult=mvc.perform(post("/api/users/signin").contentType(MediaType.APPLICATION_JSON).content(objectMapper.writeValueAsString(signin))).andDo(print()).andExpect(status().isOk()).andReturn();
		String response=signinResult.getResponse().getContentAsString();
		SignInResponse signinResponse=objectMapper.readValue(response, SignInResponse.class);
		this.accessToken=signinResponse.getAccessToken();
		this.refreshToken=signinResponse.getRefreshToken();
	}
	
	
	@Test
	@Order(1)
	void testGetUser() throws Exception{
		MvcResult getUser=mvc.perform(
					get("/api/users/getUser")
						.contentType(MediaType.APPLICATION_JSON)
						.header("Authorization", String.format("Bearer %s",this.accessToken))
						
				)
				.andDo(print())
				.andExpect(status().isOk())
				.andReturn();
		
	}
	
	@Test
	@Order(2)
	void testRefresh() throws Exception{
		RefreshRequest refreshRequest=new RefreshRequest(this.refreshToken);
		MvcResult refresh=mvc.perform(
					post("/api/users/refresh")
						.header("Authorization", String.format("Bearer %s",this.accessToken))
						.contentType(MediaType.APPLICATION_JSON)
						.content(objectMapper.writeValueAsString(refreshRequest))
				).andExpect(status().isOk())
				.andReturn();
		String response=refresh.getResponse().getContentAsString();
		RefreshResponse refreshResponse=objectMapper.readValue(response,RefreshResponse.class);
		this.newAccessToken=refreshResponse.getAccessToken();
		this.newRefreshToken=refreshResponse.getRefreshToken();
	}
	
	
	@Test
	@Order(3)
	void testLogout() throws Exception{
		MvcResult logout=mvc.perform(
					delete("/api/users/logout")
					.header("Authorization", String.format("Bearer %s",this.newAccessToken))
						.contentType(MediaType.APPLICATION_JSON)
				).andExpect(status().isOk())
				.andReturn();
	}
	

